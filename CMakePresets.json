{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "include": [
        "CMakePresetsBase.json"
    ],
    "configurePresets": [
        {
            "name": "msvc-md",
            "displayName": "msvc with dynamic CRT",
            "description": "md links CRT dynamically (/MD)",
            "inherits": [
                "basic_paths",
                "vcpkg",
                "msvc145-x64-md"
            ],
            "generator": "Visual Studio 18 2026",
            "cacheVariables": {}
        },
        {
            "name": "msvc-mt",
            "displayName": "msvc with static CRT",
            "description": "mt links CRT statically (/MT)",
            "inherits": [
                "basic_paths",
                "vcpkg",
                "msvc145-x64-mt"
            ],
            "generator": "Visual Studio 18 2026",
            "cacheVariables": {
                
            }
        },
        {
            "name": "clang-22-release",
            "inherits": [
                "basic_paths",
                "vcpkg",
                "clang-22",
                "ninja"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "clang-22-debug",
            "inherits": [
                "basic_paths",
                "vcpkg",
                "clang-22",
                "ninja"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "clang-22-aarch64-release",
            "inherits": [
                "basic_paths",
                "vcpkg",
                "clang-22-aarch64",
                "ninja"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        },
        {
            "name": "clang-22-aarch64-debug",
            "inherits": [
                "basic_paths",
                "vcpkg",
                "clang-22-aarch64",
                "ninja"
            ],
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "msvc-md-release",
            "configurePreset": "msvc-md",
            "jobs": 0,
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "msvc-md-debug",
            "configurePreset": "msvc-md",
            "jobs": 0,
            "configuration": "Debug"
        },
        {
            "name": "msvc-mt-release",
            "configurePreset": "msvc-mt",
            "jobs": 0,
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "msvc-mt-debug",
            "configurePreset": "msvc-mt",
            "jobs": 0,
            "configuration": "Debug"
        },
        {
            "name": "clang-22-release",
            "configurePreset": "clang-22-release",
            "jobs": 0
        },
        {
            "name": "clang-22-debug",
            "configurePreset": "clang-22-debug",
            "jobs": 0
        },
        {
            "name": "clang-22-aarch64-release",
            "configurePreset": "clang-22-aarch64-release",
            "jobs": 0
        },
        {
            "name": "clang-22-aarch64-debug",
            "configurePreset": "clang-22-aarch64-debug",
            "jobs": 0
        },
        {
            "name": "clang-22-aarch64-release-install",
            "configurePreset": "clang-22-aarch64-release",
            "jobs": 0,
            "targets": [
                "install"
            ]
        }

    ],
    "testPresets": [
        {
            "name": "msvc-md-debug",
            "configurePreset": "msvc-md",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "msvc-md-release",
            "configurePreset": "msvc-md",
            "configuration": "RelWithDebInfo",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "msvc-mt-debug",
            "configurePreset": "msvc-mt",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "msvc-mt-release",
            "configurePreset": "msvc-mt",
            "configuration": "RelWithDebInfo",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "clang-22-debug",
            "configurePreset": "clang-22-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "clang-22-release",
            "configurePreset": "clang-22-release",
            "output": {
                "outputOnFailure": true
            }
        }
    ],
    "workflowPresets": [
        {
            "name": "windows-release-install",
            "steps": [
                {
                    "type": "configure",
                    "name": "msvc-md"
                },
                {
                    "type": "build",
                    "name": "msvc-md-release"
                }
            ]
        },
        {
            "name": "windows-debug-install",
            "steps": [
                {
                    "type": "configure",
                    "name": "msvc-mt"
                },
                {
                    "type": "build",
                    "name": "msvc-mt-debug"
                }
            ]
        },
        {
            "name": "linux-release-install",
            "steps": [
                {
                    "type": "configure",
                    "name": "clang-22-release"
                },
                {
                    "type": "build",
                    "name": "clang-22-release"
                }
            ]
        },
        {
            "name": "linux-debug-install",
            "steps": [
                {
                    "type": "configure",
                    "name": "clang-22-debug"
                },
                {
                    "type": "build",
                    "name": "clang-22-debug"
                }
            ]
        },
        {
            "name": "linux-aarch64-release-install",
            "steps": [
                {
                    "type": "configure",
                    "name": "clang-22-aarch64-release"
                },
                {
                    "type": "build",
                    "name": "clang-22-aarch64-release"
                }
            ]
        },
        {
            "name": "linux-aarch64-debug-install",
            "steps": [
                {
                    "type": "configure",
                    "name": "clang-22-aarch64-debug"
                },
                {
                    "type": "build",
                    "name": "clang-22-aarch64-debug"
                }
            ]
        }
    ]
}