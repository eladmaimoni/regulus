{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "basic_paths",
            "hidden": true,
            "binaryDir": "${fileDir}/target/${presetName}",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${fileDir}/installed"
            }
        },
        {
            "name": "ninja",
            "description": "Sets Ninja, tells ninja to export compile database (compile_commands.json)",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": true
            },
            "generator": "Ninja"
        },
        {
            "name": "vcpkg",
            "description": "configures vcpkg and install directories",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": {
                    "value": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
                    "type": "FILEPATH"
                },
                "VCPKG_MANIFEST_DIR": "${fileDir}/cpp",
                "VCPKG_INSTALLED_DIR": "${fileDir}/vcpkg_installed"
            }
        },
        {
            "name": "msvc145-x64-md",
            "hidden": true,
            "description": "Target MSVC (Visual Studio 2026) x64",
            "generator": "Visual Studio 18 2026",
            "toolset": {
                "value": "host=x64",
                "strategy": "external"
            },
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "MSVC_TOOLSET_VERSION": "145",
                "VCPKG_TARGET_TRIPLET": "x64-windows-static-md",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
            },
            "vendor": {
                "microsoft.com/VisualStudioSettings/CMake/1.0": {
                    "hostOS": [
                        "Windows"
                    ],
                    "enableClangTidyCodeAnalysis": true
                }
            }
        },
        {
            "name": "msvc145-x64-mt",
            "hidden": true,
            "description": "Target MSVC (Visual Studio 2026) x64",
            "generator": "Visual Studio 18 2026",
            "toolset": {
                "value": "host=x64",
                "strategy": "external"
            },
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe",
                "MSVC_TOOLSET_VERSION": "145",
                "VCPKG_TARGET_TRIPLET": "x64-windows-static",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>"
            },
            "vendor": {
                "microsoft.com/VisualStudioSettings/CMake/1.0": {
                    "hostOS": [
                        "Windows"
                    ],
                    "enableClangTidyCodeAnalysis": true
                }
            }
        },
        {
            "name": "clang-22",
            "hidden": true,
            "description": "Compile with clang 20",
            "toolset": {
                "value": "host=x64",
                "strategy": "external"
            },
            "architecture": {
                "value": "x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-linux-clang-22",
                "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${fileDir}/cpp/vcpkg_scripts/toolchains/clang-22-toolchain.cmake"
            }
        },
        {
            "name": "clang-22-aarch64",
            "hidden": true,
            "description": "Cross-compile with clang 20 targeting aarch64",
            "toolset": {
                "value": "host=x64",
                "strategy": "external"
            },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "aarch64-linux-clang-22",
                "VCPKG_CHAINLOAD_TOOLCHAIN_FILE": "${fileDir}/cpp/vcpkg_scripts/toolchains/clang-22-toolchain-aarch64.cmake",
                "Rust_CARGO_TARGET": "aarch64-unknown-linux-gnu",
                "REGULUS_WITH_TESTS": "OFF"
            }
        }
    ]
}